[{"data":1,"prerenderedAt":187},["ShallowReactive",2],{"team-elisabet-periz-fernandez-en":3},{"page":4,"rest":32},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":28,"bio":30,"email":31,"linkedin":22},"aAR8uJHFSOWVsGGC0r3wew","elisabet-periz-fernandez","Elisabet Pèriz Fernández","Director of Finance and Operations",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":15,"height":16,"thumbnail":17,"small":18,"medium":19,"responsiveImage":20,"video":11},"ZLmKTqDMQ9WU_OotDtmifw",null,{"x":13,"y":14},0.45,0.35,480,640,"/assets/datocms/1764087575-epf_pic.jpeg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1764087575-epf_pic.jpeg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1764087575-epf_pic.jpeg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":21,"webpSrcSet":22,"sizes":23,"src":24,"width":15,"height":16,"aspectRatio":25,"alt":11,"title":11,"base64":26,"bgColor":27},"/assets/datocms/1764087575-epf_pic.jpeg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 120w,/assets/datocms/1764087575-epf_pic.jpeg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 240w,/assets/datocms/1764087575-epf_pic.jpeg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 360w,/assets/datocms/1764087575-epf_pic.jpeg?auto=format&fit=max&h=2440&q=85&w=2440 480w","","(max-width: 480px) 100vw, 480px","/assets/datocms/1764087575-epf_pic.jpeg?auto=format&fit=max&h=2440&q=85&w=2440",0.75,"data:image/jpeg;base64,","#d55e3c",{"hex":29},"#F37030","\u003Cp>Elisabet P&egrave;riz Fern&aacute;ndez is the Director of Finance and Operations at R&iacute;os. She is a Catalan economist, specializing in international relations and development, bringing 18 years of dedicated experience in the non-profit sector to our organization.\u003C/p>\n\u003Cp>Prior to joining R&iacute;os, Elisabet spent 13 years in Colombia working with human rights NGOs. During this time, she held various roles, including researcher and Executive Director, concentrating on critical issues such as armed conflict, the rights of peasant and ethnic communities, the impacts of natural resource extraction, environmental justice, and business and human rights.\u003C/p>\n\u003Cp>Elisabet has published articles on business and human rights and the impacts of natural resource extraction in Colombia. She has also led training sessions for civil society organizations.\u003C/p>\n\u003Cp>Elisabet's academic background includes an Economics degree from the Universitat de Barcelona and a Master&rsquo;s degree in International Relations and Development from the Universitat Aut&ograve;noma de Barcelona. In addition to being a native Catalan and Spanish speaker, she is fluent in Portuguese, French and English.\u003C/p>","elisabet@riossocialjustice.org",[33,55,75,97,120,143,165],{"id":34,"name":35,"slug":36,"role":37,"photo":38,"outline":53},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman","Co-Executive Director",{"id":39,"alt":11,"title":11,"focalPoint":40,"width":42,"height":42,"thumbnail":43,"small":44,"medium":45,"responsiveImage":46,"video":11},"KStwRHp-R_efZJrfuprKIA",{"x":41,"y":41},0.5,400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":47,"webpSrcSet":22,"sizes":48,"src":49,"width":42,"height":42,"aspectRatio":50,"alt":11,"title":11,"base64":51,"bgColor":52},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 200w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 300w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w=2440 400w","(max-width: 400px) 100vw, 400px","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w