[{"data":1,"prerenderedAt":187},["ShallowReactive",2],{"team-oscar-cabrera-en":3},{"page":4,"rest":32},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":28,"bio":30,"email":31,"linkedin":22},"PRyoLHIvTdS-35tv-G8jUA","oscar-cabrera","Oscar Cabrera","Co-Executive Director",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":15,"height":16,"thumbnail":17,"small":18,"medium":19,"responsiveImage":20,"video":11},"TkB4dklGSx25yEWY4DmenQ",null,{"x":13,"y":14},0.45,0.28,480,509,"/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":21,"webpSrcSet":22,"sizes":23,"src":24,"width":15,"height":16,"aspectRatio":25,"alt":11,"title":11,"base64":26,"bgColor":27},"/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 120w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 240w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 360w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=2440&q=85&w=2440 480w","","(max-width: 480px) 100vw, 480px","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=2440&q=85&w=2440",0.9430255402750491,"data:image/jpeg;base64,","#0a9773",{"hex":29},"#D3E173","\u003Cp>Oscar also co-directs the Center for Health and Human Rights at Georgetown University&rsquo;s O&rsquo;Neill Institute for National and Global Health Law, and. He was the executive director of the O&rsquo;Neill Institute from 2010 until 2018. Osca is a visiting professor at Georgetown Law.\u003C/p>\n\u003Cp>He has worked on projects with the World Health Organization, the Centers for Disease Control and Prevention, and the Campaign for Tobacco Free Kids, among other organizations. He has studied and published in various health law related fields, such as public health law, sexual and reproductive rights, health and human rights, global tobacco litigation, and health systems law and policy.\u003C/p>\n\u003Cp>Oscar earned his Bachelor of Laws in his home country of Venezuela at the Universidad Cat&oacute;lica Andr&eacute;s Bello. He was awarded the Canadian Institute of Health Research (CIHR) Health Law and Policy Fellowship for his master&rsquo;s program; he earned his LL.M., with focus in health law and policy, at the University of Toronto.\u003C/p>","oscar@riossocialjustice.org",[33,54,76,100,120,143,165],{"id":34,"name":35,"slug":36,"role":8,"photo":37,"outline":52},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman",{"id":38,"alt":11,"title":11,"focalPoint":39,"width":41,"height":41,"thumbnail":42,"small":43,"medium":44,"responsiveImage":45,"video":11},"KStwRHp-R_efZJrfuprKIA",{"x":40,"y":40},0.5,400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":46,"webpSrcSet":22,"sizes":47,"src":48,"width":41,"height":41,"aspectRatio":49,"alt":11,"title":11,"base64":50,"bgColor":51},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 200w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 300w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w=2440 400w","(max-width: 400px) 100vw, 400px","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w=2440",1,"data:image/jpeg;base64,","#b9825f",{"hex":53},"#115767",{"id":55,"name":56,"slug":57,"role":58,"photo":59,"outline":74},"GaSXNXFBSVKD2GgiwwKkLA","Analía Banfi","analia-banfi","Deputy Executive Director",{"id"