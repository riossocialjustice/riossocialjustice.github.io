[{"data":1,"prerenderedAt":187},["ShallowReactive",2],{"team-selene-soto-rodriguez-en":3},{"page":4,"rest":31},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":27,"bio":29,"email":30,"linkedin":21},"TTfIvutPSMep6ustrOQSxA","selene-soto-rodriguez","Selene Soto Rodríguez","Senior Legal Advisor",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":15,"height":15,"thumbnail":16,"small":17,"medium":18,"responsiveImage":19,"video":11},"MYz5IqHGRfGgX2zMRH-z3Q",null,{"x":13,"y":14},0.6,0.33,300,"/assets/datocms/1763550764-headshot-8.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-8.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-8.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":20,"webpSrcSet":21,"sizes":22,"src":23,"width":15,"height":15,"aspectRatio":24,"alt":11,"title":11,"base64":25,"bgColor":26},"/assets/datocms/1763550764-headshot-8.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 75w,/assets/datocms/1763550764-headshot-8.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 150w,/assets/datocms/1763550764-headshot-8.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 225w,/assets/datocms/1763550764-headshot-8.jpg?auto=format&fit=max&h=2440&q=85&w=2440 300w","","(max-width: 300px) 100vw, 300px","/assets/datocms/1763550764-headshot-8.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1,"data:image/jpeg;base64,","#90393c",{"hex":28},"#771216","\u003Cp>Selene Soto Rodr&iacute;guez is a Senior Legal Advisor at R&iacute;os and a Venezuelan lawyer specializing in human rights and gender, with 17 years of experience.\u003C/p>\n\u003Cp>Before joining R&iacute;os, she worked in international organizations focused on strategic litigation related to sexual and reproductive rights, gender-based violence affecting migrant women and trafficking victims, as well as in humanitarian and transitional justice contexts. She spent over seven years at the Inter-American Commission on Human Rights (IACHR), where she held various positions in thematic rapporteurships, including LGBTI persons and women&rsquo;s rights, monitored several countries in the region, and worked on cases before the Inter-American Court of Human Rights. In Venezuela, she worked with COFAVIC, an NGO focused on justice for serious human rights violations. She is the editor and co-author of The Bel&eacute;m do Par&aacute; Convention: Commentary on Its History, Developments, and Current Debates, published by the Konrad Adenauer Foundation.\u003C/p>\n\u003Cp>Selene graduated from Universidad Cat&oacute;lica Andr&eacute;s Bello and holds advanced studies in international law. She is a candidate for the Master's in Constitutional Law at Universidad Externado de Colombia and is currently pursuing a Master's in Women&rsquo;s Studies at Universidad Central de Venezuela. She is a member of RELEG and a collaborator with the GenEq Institute.\u003C/p>","selene@riossocialjustice.org",[32,53,76,98,122,142,165],{"id":33,"name":34,"slug":35,"role":36,"photo":37,"outline":51},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman","Co-Executive Director",{"id":38,"alt":11,"title":11,"focalPoint":39,"width":41,"height":41,"thumbnail":42,"small":43,"medium":44,"responsiveImage":45,"video":11},"KStwRHp-R_efZJrfuprKIA",{"x":40,"y":40},0.5,400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":46,"webpSrcSet":21,"sizes":47,"src":48,"width":41,"height":41,"aspectRatio":24,"alt":11,"title":11,"base64":49,"bgColor":50},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 200w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=