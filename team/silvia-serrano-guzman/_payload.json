[{"data":1,"prerenderedAt":187},["ShallowReactive",2],{"team-silvia-serrano-guzman-en":3},{"page":4,"rest":30},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":26,"bio":28,"email":29,"linkedin":20},"OtPTU6GHQhS5GfVPnYlpnw","silvia-serrano-guzman","Silvia Serrano-Guzmán","Co-Executive Director",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":14,"height":14,"thumbnail":15,"small":16,"medium":17,"responsiveImage":18,"video":11},"KStwRHp-R_efZJrfuprKIA",null,{"x":13,"y":13},0.5,400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":19,"webpSrcSet":20,"sizes":21,"src":22,"width":14,"height":14,"aspectRatio":23,"alt":11,"title":11,"base64":24,"bgColor":25},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 200w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 300w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w=2440 400w","","(max-width: 400px) 100vw, 400px","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=2440&q=85&w=2440",1,"data:image/jpeg;base64,","#b9825f",{"hex":27},"#115767","\u003Cp>Silvia also co-directs the Center for Health and Human Rights at Georgetown University&rsquo;s O&rsquo;Neill Institute for National and Global Health Law and is also an adjunct professor at Georgetown Law and teaches international human rights litigation in different universities across Latin America and Europe.\u003C/p>\n\u003Cp>Formerly, Silvia was an attorney at the Inter-American Commission on Human Rights (IACHR) for 14 years. She led the Case Section, managing the portfolio of thousands of cases regarding the 35 member states of the OAS and being responsible for the litigation of all the cases submitted cases presented to the Inter-American Court of Human Rights.\u003C/p>\n\u003Cp>Silvia obtained her law degree at the Universidad Aut&oacute;noma de Bucaramanga. She holds an LL.M. in international legal studies and international human rights law from \u003Cspan>Georgetown University Law Center and an M.A. in legal argumentation from the University of Alicante. She is currently an S.J.D. candidate at Georgetown University Law Center, focusing in discrimination and structural inequality.\u003C/span>\u003C/p>","silvia@riossocialjustice.org",[31,54,76,100,120,143,165],{"id":32,"name":33,"slug":34,"role":8,"photo":35,"outline":52},"PRyoLHIvTdS-35tv-G8jUA","Oscar Cabrera","oscar-cabrera",{"id":36,"alt":11,"title":11,"focalPoint":37,"width":40,"height":41,"thumbnail":42,"small":43,"medium":44,"responsiveImage":45,"video":11},"TkB4dklGSx25yEWY4DmenQ",{"x":38,"y":39},0.45,0.28,480,509,"/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":46,"webpSrcSet":20,"sizes":47,"src":48,"width":40,"height":41,"aspectRatio":49,"alt":11,"title":11,"base64":50,"bgColor":51},"/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 120w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 240w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 360w,/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=2440&q=85&w=2440 480w","(max-width: 480px) 100vw, 480px","/assets/datocms/1764087557-oac_pic1.jpeg?auto=format&fit=max&h=2440&q=85&w=2440",0.9430255402750491,"data:image/jpeg;base64,","#0a9773",{"hex":53},"#D3E173",{"id":55,"name":56,"slug":57,"role":58,"photo":59,"outline":74},"GaSXNXFBSVKD2G