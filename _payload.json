[{"data":1,"prerenderedAt":130},["ShallowReactive",2],{"home-en":3},{"page":4,"latest":-1},{"id":5,"hero":6,"mission":26,"about":29,"work":47,"seo":10},"YfQnY3ifTj-391KuLH7cAw",{"title":7,"media":8},"\u003Cp>LEGAL INNOVATION \u003Cbr>\u003Cem>FOR SOCIAL CHANGE\u003C/em>\u003C/p>",{"id":9,"alt":10,"title":10,"focalPoint":11,"width":13,"height":14,"thumbnail":15,"small":16,"medium":17,"responsiveImage":18,"video":10},"fXBx3KlvTLWb7NTaidE08A",null,{"x":12,"y":12},0.5,2082,1392,"/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":19,"webpSrcSet":20,"sizes":21,"src":22,"width":13,"height":14,"aspectRatio":23,"alt":10,"title":10,"base64":24,"bgColor":25},"/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 520w,/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1041w,/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1561w,/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2082w","","(max-width: 2082px) 100vw, 2082px","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.4956896551724137,"data:image/jpeg;base64,","#c21e2f",{"title":27,"text":28},"OUR MISSION","\u003Cp>\u003Cem>R&iacute;os Strategic Lawyering for Social Justice \u003C/em>is a nonprofit organization advancing social justice through innovative legal action and research. We use the law strategically to build more just, equitable societies, grounding our work in real-world challenges and pushing for legal frameworks and public policies that protect human rights. Some of our key areas of work include advancing sexual and reproductive health, ensuring access to justice to all, and strengthening the rule of law to drive lasting, transformative changes.\u003C/p>",{"title":30,"text":31,"media":32},"ABOUT RÍOS","\u003Cp>R&iacute;os was founded with the core vision of creating a collaborative environment where law and human rights are used strategically and creatively to advance social justice. Like rivers that shape landscapes, we believe legal work should be adaptable and capable of reshaping and transforming realities.\u003C/p>",{"id":33,"alt":10,"title":10,"focalPoint":34,"width":35,"height":36,"thumbnail":37,"small":38,"medium":39,"responsiveImage":40,"video":10},"ddKFC1FlS2aKdmCICSxTEA",{"x":12,"y":12},2100,1396,"/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":41,"webpSrcSet":20,"sizes":42,"src":43,"width":35,"height":36,"aspectRatio":44,"alt":10,"title":10,"base64":45,"bgColor":46},"/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 525w,/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1050w,/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1575w,/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2100w","(max-width: 2100px) 100vw, 2100px","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.504297994269341,"data:image/jpeg;base64,","#1d599a",{"title":48,"text":49,"items":50},"OUR WORK","\u003Cp>Our current priorities include advancing sexual and reproductive health, securing access to justice for historically marginalized communities, and addressing emerging global challenges. At the same time, we remain committed to strengthening the foundations of impactful legal work, reinforcing the rule of law and building legal capacity where it's needed most.\u003C/p>",[51,72,91,111],{"id":52,"title":53,"text":54,"media":55},"d-VR_p9tREW4o67mw7jWlg","SEXUAL AND REPRODUCTIVE HEALTH","\u003Cp>Through innovative and strategic use of the law, we work to advance women's reproductive health in all its dimensions, particularly by promoting the decriminalization of abortion and expanding access to legal and safe abortion services.\u003C/p>",{"id":56,"alt":10,"title":10,"focalPoint":57,"width":58,"height":59,"thumbnail":60,"small":61,"medium":62,"responsiveImage":63,"video":10},"emKn-u-qQWeiSah06HeLmA",{"x":12,"y":12},3000,2000,"/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":64,"webpSrcSet":20,"sizes":65,"src":66,"width":67,"height":68,"aspectRatio":69,"alt":10,"title":10,"base64":70,"bgColor":71},"/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2440w","(max-width: 2440px) 100vw, 2440px","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=2440&q=85&w=2440",2440,1626,1.5,"data:image/jpeg;base64,","#d5061e",{"id":73,"title":74,"text":75,"media":76},"FaJvVaD_S5e8jplYRW9QxA","REGIONAL INITIATIVES","\u003Cp>Since October 2022, R&iacute;os, together with the feminist lawyer Ximena Casas, has been developing a multidimensional strategy to generate empirical evidence that illuminates the consequences of using criminal law to regulate abortion.\u003C/p>",{"id":77,"alt":10,"title":10,"focalPoint":78,"width":79,"height":80,"thumbnail":81,"small":82,"medium":83,"responsiveImage":84,"video":10},"Ym3kyXWrRa2ZvHbfc21AXA",{"x":12,"y":12},2102,1570,"/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":85,"webpSrcSet":20,"sizes":86,"src":87,"width":79,"height":80,"aspectRatio":88,"alt":10,"title":10,"base64":89,"bgColor":90},"/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 525w,/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1051w,/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1576w,/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2102w","(max-width: 2102px) 100vw, 2102px","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.3388535031847133,"data:image/jpeg;base64,","#0287d7",{"id":92,"title":93,"text":94,"media":95},"PMeg-jzvQvGc8SkjWWdMQg","LITIGATION AND REPRESENTATION","\u003Cp>At R&iacute;os, we believe that the strategically engaging international justice mechanisms is essential to advancing legal and policy reforms that build more just and equitable societies. That&rsquo;s why our work includes litigation and advocacy before international human rights bodies.\u003C/p>",{"id":96,"alt":10,"title":10,"focalPoint":97,"width":100,"height":101,"thumbnail":102,"small":103,"medium":104,"responsiveImage":105,"video":10},"LythDjPhQpG60MZVmMMh3A",{"x":98,"y":99},0.37,0.47,1920,1280,"/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":106,"webpSrcSet":20,"sizes":107,"src":108,"width":100,"height":101,"aspectRatio":69,"alt":10,"title":10,"base64":109,"bgColor":110},"/assets/datocms/1761477623-home-3.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 480w,/ass