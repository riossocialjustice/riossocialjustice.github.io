[{"data":1,"prerenderedAt":249},["ShallowReactive",2],{"about-en":3},{"page":4,"team":51,"belen":229},{"id":5,"hero":6,"history":26,"team":29,"board":32,"seo":10},"DZxAUi56R96ULbVl9jGbjQ",{"title":7,"media":8},"\u003Cp>About Us\u003C/p>",{"id":9,"alt":10,"title":10,"focalPoint":11,"width":13,"height":14,"thumbnail":15,"small":16,"medium":17,"responsiveImage":18,"video":10},"XyGzMHDRTICGHGKcrL7fYw",null,{"x":12,"y":12},0.5,2082,1344,"/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":19,"webpSrcSet":20,"sizes":21,"src":22,"width":13,"height":14,"aspectRatio":23,"alt":10,"title":10,"base64":24,"bgColor":25},"/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 520w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1041w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1561w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2082w","","(max-width: 2082px) 100vw, 2082px","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.5491071428571428,"data:image/jpeg;base64,","#f95868",{"title":27,"text":28},"History","\u003Cp>R&iacute;os was founded with the core vision of creating a collaborative environment where law and human rights are used strategically and creatively to advance social justice. Like rivers that shape landscapes, we believe legal work should be adaptable and capable of reshaping and transforming realities.\u003C/p>\n\u003Cp>Our team brings decades of legal and research expertise, driving meaningful impact across a wide range of human rights issues at both global and local levels.\u003C/p>\n\u003Cp>Since its founding, R&iacute;os has built strategic partnerships with academic institutions, legal experts, and organizations. A key ally in this work is the \u003Ca href=\"https://oneill.law.georgetown.edu/centers/health-and-human-rights/\" target=\"_blank\" rel=\"noopener\">Center for Health and Human Rights\u003C/a> at Georgetown University's O'Neill Institute for National and Global Health Law. In recent years, R&iacute;os has significantly expanded its network and extended the reach of its efforts across new regions and communities.\u003C/p>",{"title":30,"text":31},"Our People","\u003Cp>Our team brings decades of legal and research expertise, driving meaningful impact across a wide range of human rights issues at both global and local levels.\u003C/p>",{"title":33,"items":34},"Advisory Board",[35,39,43,47],{"id":36,"name":37,"text":38},"Jojgsit4TdWrYkmdft6rAw","ANGELITA BAEYENS","\u003Cp>Robert F. Kennedy Human Rights \u003Cbr />\u003Cem>VP of International Advocacy and Litigation\u003C/em>\u003C/p>",{"id":40,"name":41,"text":42},"Lh-cXz9gQbq0XFrjmDNTxA","GIANELLA SEVERINI","\u003Cp>Global Health Advocacy Incubator \u003Cbr />\u003Cem>Senior Legal Advisor\u003C/em>\u003C/p>",{"id":44,"name":45,"text":46},"QB7ubFGxQLazu0mzozqq5Q","JILL MORRISON","\u003Cp>Georgetown Law \u003Cbr />\u003Cem>Director, Leadership and Advocacy for Women in Africa Program; Director, Women&rsquo;s Law and Public Policy Fellowship; Visiting Professor of Law\u003C/em>\u003C/p>",{"id":48,"name":49,"text":50},"HnfdWhpuTPKesN-ozeUkqA","MARTÍN HEVIA","\u003Cp>Universidad Torcuato Di Tella \u003Cbr />\u003Cem>Vice-Rector and full professor at the School of Law\u003C/em>\u003C/p>",[52,73,96,118,142,162,185,207],{"id":53,"name":54,"slug":55,"role":56,"photo":57,"outline":71},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman","Co-Executive Director",{"id":58,"alt":10,"title":10,"focalPoint":59,"width":60,"height":60,"thumbnail":61,"small":62,"medium":63,"responsiveImage":64,"video":10},"KStwRHp-R_efZJrfuprKIA",{"x":12,