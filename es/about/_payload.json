[{"data":1,"prerenderedAt":243},["ShallowReactive",2],{"about-es":3},{"page":4,"team":51,"belen":223},{"id":5,"hero":6,"history":26,"team":29,"board":32,"seo":10},"DZxAUi56R96ULbVl9jGbjQ",{"title":7,"media":8},"\u003Cp>Qui&eacute;nes somos\u003C/p>",{"id":9,"alt":10,"title":10,"focalPoint":11,"width":13,"height":14,"thumbnail":15,"small":16,"medium":17,"responsiveImage":18,"video":10},"XyGzMHDRTICGHGKcrL7fYw",null,{"x":12,"y":12},0.5,2082,1344,"/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":19,"webpSrcSet":20,"sizes":21,"src":22,"width":13,"height":14,"aspectRatio":23,"alt":10,"title":10,"base64":24,"bgColor":25},"/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 520w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1041w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1561w,/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2082w","","(max-width: 2082px) 100vw, 2082px","/assets/datocms/1775475962-rios-about-hero.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.5491071428571428,"data:image/jpeg;base64,","#f95868",{"title":27,"text":28},"Historia","\u003Cp>R&iacute;os naci&oacute; de la visi&oacute;n de construir un espacio colectivo para potenciar el uso estrat&eacute;gico e innovador del derecho y los derechos humanos con fines de justicia social. Como los r&iacute;os en la naturaleza, el trabajo legal para lograr sociedades m&aacute;s justas debe ser din&aacute;mico y capaz de transformar realidades.&nbsp;\u003C/p>\n\u003Cp>El equipo de R&iacute;os aporta d&eacute;cadas de experiencia en investigaci&oacute;n y trabajo legal con probado impacto en m&uacute;ltiples &aacute;reas de derechos humanos en diversos pa&iacute;ses y a nivel internacional.&nbsp;\u003C/p>\n\u003Cp>Desde su nacimiento, R&iacute;os ha trabajado en alianza estrat&eacute;gica con diversos actores acad&eacute;micos, legales y del activismo. El\u003Ca href=\"https://oneill.law.georgetown.edu/centers/health-and-human-rights/\" target=\"_blank\" rel=\"noopener\"> Centro para la Salud y los Derechos Humanos\u003C/a> del Instituto O&rsquo;Neill para el Derecho y la Salud Nacional y Global de la Universidad de Georgetown, es uno de sus principales socios y en los &uacute;ltimos a&ntilde;os R&iacute;os ha multiplicado sus alianzas y ha ampliado geogr&aacute;ficamente el alcance de su trabajo.\u003C/p>",{"title":30,"text":31},"Nuestro equipo","\u003Cp>El equipo de R&iacute;os aporta d&eacute;cadas de experiencia en investigaci&oacute;n y trabajo legal con probado impacto en m&uacute;ltiples &aacute;reas de derechos humanos en diversos pa&iacute;ses y a nivel internacional.&nbsp;\u003C/p>",{"title":33,"items":34},"Junta Directiva",[35,39,43,47],{"id":36,"name":37,"text":38},"e7XjNs84Q66iuS4dgENs0w","ANGELITA BAEYENS","\u003Cp>Robert F. Kennedy Human Rights \u003Cbr>\u003Cem>VP de Incidencia internacional y Litigio\u003C/em>\u003C/p>",{"id":40,"name":41,"text":42},"dawyJk9zQuWiqwyMWKKq0Q","GIANELLA SEVERINI","\u003Cp>Global Health Advocacy Incubator \u003Cbr>\u003Cem>Asesora Legal Senior\u003C/em>\u003C/p>",{"id":44,"name":45,"text":46},"a4usdC5iRW6buMWEmzxYJg","JILL MORRISON","\u003Cp>Facultad de Derecho de Georgetown&nbsp;\u003Cbr>\u003Cem>Directora del programa \"Leadership and Advocacy for Women in Africa\"; Directora de \"Women&rsquo;s Law and Public Policy Fellowship\"; Profesora invitada de la Facultad de Derecho\u003C/em>\u003C/p>",{"id":48,"name":49,"text":50},"CmdAERBlQgyLF84kzpsYBw","MARTÍN HEVIA","\u003Cp>Universidad Torcuato Di Tella \u003Cbr>\u003Cem>Vicerrector y profesor titular de la Facultad de Derecho\u003C/em>\u003C/p>",[52,73,95,117,141,160,181,203],{"id":53,"na