[{"data":1,"prerenderedAt":181},["ShallowReactive",2],{"team-analia-banfi-es":3},{"page":4,"rest":31},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":27,"bio":29,"email":30,"linkedin":21},"GaSXNXFBSVKD2GgiwwKkLA","analia-banfi","Analía Banfi","Subdirectora",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":14,"height":15,"thumbnail":16,"small":17,"medium":18,"responsiveImage":19,"video":11},"SWUrxJr_TLOM_54FcL8IxQ",null,{"x":13,"y":13},0.5,416,414,"/assets/datocms/1763550764-headshot-2.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-2.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-2.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":20,"webpSrcSet":21,"sizes":22,"src":23,"width":14,"height":15,"aspectRatio":24,"alt":11,"title":11,"base64":25,"bgColor":26},"/assets/datocms/1763550764-headshot-2.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 104w,/assets/datocms/1763550764-headshot-2.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 208w,/assets/datocms/1763550764-headshot-2.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 312w,/assets/datocms/1763550764-headshot-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440 416w","","(max-width: 416px) 100vw, 416px","/assets/datocms/1763550764-headshot-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.0048309178743962,"data:image/jpeg;base64,","#cc8a38",{"hex":28},"#BE1E2D","\u003Cp>Anal&iacute;a Banfi es la Subdirectora de R&iacute;os. Abogada uruguaya especializada en derecho internacional de los derechos humanos, Anal&iacute;a tambi&eacute;n es profesora adjunta en la Facultad de Derecho de Georgetown.&nbsp;Antes de incorporarse a R&iacute;os, Anal&iacute;a trabaj&oacute; durante 15 a&ntilde;os en la Comisi&oacute;n Interamericana de Derechos Humanos, donde ocup&oacute; varios cargos. En sus funciones de liderazgo, supervis&oacute; la redacci&oacute;n de decisiones de admisibilidad, contribuy&oacute; a las decisiones sobre el fondo y prest&oacute; apoyo en litigios ante la Corte Interamericana de Derechos Humanos. Su trabajo abarc&oacute; una amplia gama de cuestiones de derechos humanos. Tambi&eacute;n supervis&oacute; la situaci&oacute;n de los derechos humanos en Hait&iacute;, Brasil, Estados Unidos y el Caribe angl&oacute;fono.\u003C/p>\n\u003Cp>Anal&iacute;a ha publicado numerosos art&iacute;culos sobre diversos aspectos del sistema interamericano de derechos humanos y ha impartido sesiones de formaci&oacute;n para organizaciones de la sociedad civil y funcionarios p&uacute;blicos. Anal&iacute;a obtuvo su licenciatura en Derecho y en Relaciones Internacionales en la Universidad de la Rep&uacute;blica de Uruguay, una maestr&iacute;a en Derechos Humanos y Derecho Humanitario en la Universidad de Par&iacute;s II, Panth&eacute;on-Assas, en Francia, y un certificado en Estudios de Migraci&oacute;n Internacional en la Universidad de Georgetown. Es nativa de espa&ntilde;ol y domina el ingl&eacute;s, el portugu&eacute;s y el franc&eacute;s.\u003C/p>","analia@riossocialjustice.org",[32,53,75,99,118,139,161],{"id":33,"name":34,"slug":35,"role":36,"photo":37,"outline":51},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman","Co-Directora Ejecutiva",{"id":38,"alt":11,"title":11,"focalPoint":39,"width":40,"height":40,"thumbnail":41,"small":42,"medium":43,"responsiveImage":44,"video":11},"KStwRHp-R_efZJrfuprKIA",{"x":13,"y":13},400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":45,"webpSrcSet":21,"sizes":46,"src":47,"width":40,"height":40,"aspectRatio":48,"alt":11,"title":11,"base64":49,"bgColor":50},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w,/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.5&fit=max&h=24