[{"data":1,"prerenderedAt":188},["ShallowReactive",2],{"team-laura-dragnic-toha-es":3},{"page":4,"rest":32},{"id":5,"slug":6,"name":7,"role":8,"photo":9,"outline":28,"bio":30,"email":31,"linkedin":22},"fWQNQIGGQw-aCJtGZHEz6w","laura-dragnic-toha","Laura Dragnic Tohá","Asesora Legal",{"id":10,"alt":11,"title":11,"focalPoint":12,"width":15,"height":16,"thumbnail":17,"small":18,"medium":19,"responsiveImage":20,"video":11},"SQQWtq1nTiSxwKDnTOf6gg",null,{"x":13,"y":14},0.53,0.34,1280,1254,"/assets/datocms/1763550764-headshot-5.jpeg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-5.jpeg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-5.jpeg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":21,"webpSrcSet":22,"sizes":23,"src":24,"width":15,"height":16,"aspectRatio":25,"alt":11,"title":11,"base64":26,"bgColor":27},"/assets/datocms/1763550764-headshot-5.jpeg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 320w,/assets/datocms/1763550764-headshot-5.jpeg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 640w,/assets/datocms/1763550764-headshot-5.jpeg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 960w,/assets/datocms/1763550764-headshot-5.jpeg?auto=format&fit=max&h=2440&q=85&w=2440 1280w","","(max-width: 1280px) 100vw, 1280px","/assets/datocms/1763550764-headshot-5.jpeg?auto=format&fit=max&h=2440&q=85&w=2440",1.0207336523125996,"data:image/jpeg;base64,","#cc9178",{"hex":29},"#F37030","\u003Cp>Laura Dragnic Toh&aacute; es Asesora Jur&iacute;dica de la Iniciativa Preclusion LAC, un proyecto colaborativo entre el Preclusion Project y R&iacute;os. Anteriormente, se desempe&ntilde;&oacute; como asesora jur&iacute;dica en el Ministerio de la Mujer y de la Igualdad de Chile, donde contribuy&oacute; a iniciativas destinadas a promover la igualdad de g&eacute;nero, en particular en materia de derechos sexuales y reproductivos y el derecho a la atenci&oacute;n. Antes de eso, fue coordinadora jur&iacute;dica en la Corporaci&oacute;n Miles, donde dirigi&oacute; litigios estrat&eacute;gicos para promover los derechos sexuales y reproductivos en Chile.\u003C/p>\n\u003Cp>Laura tiene un m&aacute;ster en Derecho Nacional y Global de la Salud y un certificado en Derecho Internacional de los Derechos Humanos por la Universidad de Georgetown, donde trabaj&oacute; como asistente de investigaci&oacute;n en el O&rsquo;Neill Institute for National and Global Health Law. En el Instituto O'Neill, su investigaci&oacute;n se centr&oacute; en la despenalizaci&oacute;n del aborto, la violencia obst&eacute;trica y los an&aacute;lisis comparativos de los derechos al aborto desde una perspectiva internacional. Tambi&eacute;n es licenciada en Derecho y tiene un certificado en Mujeres y Justicia Penal de la Universidad de Chile, as&iacute; como una maestr&iacute;a en Filosof&iacute;a Pol&iacute;tica de la Universidad Diego Portales.\u003C/p>\n\u003Cp>Laura es una abogada feminista e investigadora comprometida con el uso del derecho como herramienta para la justicia social. Habla espa&ntilde;ol e ingl&eacute;s con fluidez.\u003C/p>","laura@riossocialjustice.org",[33,55,79,101,125,144,166],{"id":34,"name":35,"slug":36,"role":37,"photo":38,"outline":53},"OtPTU6GHQhS5GfVPnYlpnw","Silvia Serrano-Guzmán","silvia-serrano-guzman","Co-Directora Ejecutiva",{"id":39,"alt":11,"title":11,"focalPoint":40,"width":42,"height":42,"thumbnail":43,"small":44,"medium":45,"responsiveImage":46,"video":11},"KStwRHp-R_efZJrfuprKIA",{"x":41,"y":41},0.5,400,"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":47,"webpSrcSet":22,"sizes":48,"src":49,"width":42,"height":42,"aspectRatio":50,"alt":11,"title":11,"base64":51,"bgColor":52},"/assets/datocms/1763550764-headshot-9-jpg.avif?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 100w