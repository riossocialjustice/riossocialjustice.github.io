[{"data":1,"prerenderedAt":129},["ShallowReactive",2],{"home-es":3},{"page":4,"latest":-1},{"id":5,"hero":6,"mission":26,"about":29,"work":47,"seo":10},"YfQnY3ifTj-391KuLH7cAw",{"title":7,"media":8},"\u003Cp>INNOVACI&Oacute;N LEGAL&nbsp;\u003Cbr>\u003Cem>PARA LA JUSTICIA SOCIAL\u003C/em>\u003C/p>",{"id":9,"alt":10,"title":10,"focalPoint":11,"width":13,"height":14,"thumbnail":15,"small":16,"medium":17,"responsiveImage":18,"video":10},"fXBx3KlvTLWb7NTaidE08A",null,{"x":12,"y":12},0.5,2082,1392,"/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":19,"webpSrcSet":20,"sizes":21,"src":22,"width":13,"height":14,"aspectRatio":23,"alt":10,"title":10,"base64":24,"bgColor":25},"/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 520w,/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1041w,/assets/datocms/1761477623-home-1.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1561w,/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2082w","","(max-width: 2082px) 100vw, 2082px","/assets/datocms/1761477623-home-1.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.4956896551724137,"data:image/jpeg;base64,","#c21e2f",{"title":27,"text":28},"NUESTRA MISIÓN","\u003Cp>\u003Cem>R&iacute;os Strategic Lawyering for Social Justice\u003C/em> es \u003Cspan lang=\"ES\" style=\"mso-bidi-font-family: Arial; color: black; mso-themecolor: text1; mso-font-kerning: 0pt; mso-ansi-language: ES;\">un centro de pensamiento, investigaci&oacute;n y acci&oacute;n legal comprometido con el uso estrat&eacute;gico e innovador del derecho para promover sociedades m&aacute;s justas y equitativas. Nuestra misi&oacute;n es contribuir a que el derecho \u003C/span>\u003Cspan lang=\"ES-UY\" style=\"mso-bidi-font-family: Arial; color: black; mso-themecolor: text1; mso-font-kerning: 0pt; mso-ansi-language: ES-UY;\">est&eacute; informado por\u003C/span>\u003Cspan lang=\"ES\" style=\"mso-bidi-font-family: Arial; color: black; mso-themecolor: text1; mso-font-kerning: 0pt; mso-ansi-language: ES;\"> las realidades sociales que busca transformar y sea acompa&ntilde;ado de pol&iacute;ticas p&uacute;blicas efectivas y respetuosas de los derechos humanos, tomando en cuenta los nuevos y crecientes desaf&iacute;os globales. Para lograrlo, en R&iacute;os centramos nuestros esfuerzos en ejes prioritarios de \u003C/span>\u003Cspan lang=\"ES\" style=\"mso-bidi-font-family: Arial; color: #141413; mso-font-kerning: 0pt; mso-ansi-language: ES;\">trabajo y, al mismo tiempo, buscamos crear las condiciones transversales necesarias para profundizar el impacto de la acci&oacute;n legal, incluyendo el fortalecimiento del Estado de derecho. \u003Cspan style=\"mso-spacerun: yes;\">&nbsp;\u003C/span>\u003C/span>\u003Cspan lang=\"ES\" style=\"mso-bidi-font-family: Arial; color: black; mso-themecolor: text1; mso-font-kerning: 0pt; mso-ansi-language: ES;\">\u003Co:p>\u003C/o:p>\u003C/span>\u003C/p>",{"title":30,"text":31,"media":32},"ACERCA DE RÍOS","\u003Cp class=\"MsoNormal\" style=\"margin-bottom: 0in; text-align: justify; line-height: normal;\">\u003Cspan lang=\"ES\" style=\"mso-bidi-font-family: Arial; color: #141413; mso-font-kerning: 0pt; mso-ansi-language: ES;\">R&iacute;os naci&oacute; de la\u003Cem> visi&oacute;n de construir un \u003C/em>espacio colectivo para potenciar el uso estrat&eacute;gico e innovador del derecho y los derechos humanos con fines de justicia social. Como los r&iacute;os en la naturaleza, el trabajo legal para lograr sociedades m&aacute;s justas debe ser din&aacute;mico y capaz de transformar realidades. \u003Co:p>\u003C/o:p>\u003C/span>\u003C/p>",{"id":33,"alt":10,"title":10,"focalPoint":34,"width":35,"height":36,"thumbnail":37,"small":38,"medium":39,"responsiveImage":40,"video":10},"ddKFC1FlS2aKdmCICSxTEA",{"x":12,"y":12},2100,1396,"/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":41,"webpSrcSet":20,"sizes":42,"src":43,"width":35,"height":36,"aspectRatio":44,"alt":10,"title":10,"base64":45,"bgColor":46},"/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 525w,/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1050w,/assets/datocms/1761477623-home-2.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1575w,/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2100w","(max-width: 2100px) 100vw, 2100px","/assets/datocms/1761477623-home-2.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.504297994269341,"data:image/jpeg;base64,","#1d599a",{"title":48,"text":49,"items":50},"NUESTRO TRABAJO","\u003Cp>Las &aacute;reas tem&aacute;ticas prioritarias de nuestro trabajo actualmente incluyen la salud sexual y reproductiva, el acceso a la justicia de grupos hist&oacute;ricamente discriminados y nuevos desaf&iacute;os globales. Al mismo tiempo, trabajamos en la creaci&oacute;n y sostenibilidad de las condiciones necesarias para la eficacia del trabajo legal, como el fortalecimiento del Estado de derecho y las capacidades legales.\u003C/p>",[51,72,91,109],{"id":52,"title":53,"text":54,"media":55},"Xz-KVncYT5uQkkGTlEVJYg","SALUD SEXUAL Y REPRODUCTIVA","\u003Cp>Mediante un uso innovador y estrat&eacute;gico del derecho, trabajamos para promover la salud reproductiva de las mujeres en todas sus dimensiones, en particular fomentando la despenalizaci&oacute;n del aborto y ampliando el acceso a servicios de aborto legales y seguros.\u003C/p>",{"id":56,"alt":10,"title":10,"focalPoint":57,"width":58,"height":59,"thumbnail":60,"small":61,"medium":62,"responsiveImage":63,"video":10},"emKn-u-qQWeiSah06HeLmA",{"x":12,"y":12},3000,2000,"/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":64,"webpSrcSet":20,"sizes":65,"src":66,"width":67,"height":68,"aspectRatio":69,"alt":10,"title":10,"base64":70,"bgColor":71},"/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2440w","(max-width: 2440px) 100vw, 2440px","/assets/datocms/1778494494-ourwork_sex_repro_rights.jpg?auto=format&fit=max&h=2440&q=85&w=2440",2440,1626,1.5,"data:image/jpeg;base64,","#d5061e",{"id":73,"title":74,"text":75,"media":76},"L7sDhZpUTV6y3GsK0c0pZw","INICIATIVAS REGIONALES","\u003Cp>Desde octubre de 2022, en coordinaci&oacute;n con la abogada feminista Ximena Casas, R&iacute;os ha venido desarrollando una estrategia multidimensional para recabar datos emp&iacute;ricos que pongan de manifiesto las consecuencias del uso del derecho penal para regular el aborto.\u003C/p>",{"id":77,"alt":10,"title":10,"focalPoint":78,"width":79,"height":80,"thumbnail":81,"small":82,"medium":83,"responsiveImage":84,"video":10},"Ym3kyXWrRa2ZvHbfc21AXA",{"x":12,"y":12},2102,1570,"/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":85,"webpSrcSet":20,"sizes":86,"src":87,"width":79,"height":80,"aspectRatio":88,"alt":10,"title":10,"base64":89,"bgColor":90},"/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 525w,/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1051w,/assets/datocms/1761477623-home-4.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1576w,/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2102w","(max-width: 2102px) 100vw, 2102px","/assets/datocms/1761477623-home-4.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.3388535031847133,"data:image/jpeg;base64,","#0287d7",{"id":92,"title":93,"text":94,"media":95},"X_QVx_mpSGmOHxo3-bgfyg","LITIGIO ESTRATÉGICO","\u003Cp>En R&iacute;os creemos que el uso estrat&eacute;gico de los mecanismos de justicia internacional es esencial para impulsar reformas legales y pol&iacute;ticas que contribuyan a construir sociedades m&aacute;s justas y equitativas. Por elloo, nuestra labor incluye el litigio y la incidencia ante organismos internacionales de derechos humanos.\u003C/p>",{"id":96,"alt":10,"title":10,"focalPoint":97,"width":98,"height":99,"thumbnail":100,"small":101,"medium":102,"responsiveImage":103,"video":10},"LythDjPhQpG60MZVmMMh3A",{"x":12,"y":12},1920,1280,"/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":104,"webpSrcSet":20,"sizes":105,"src":106,"width":98,"height":99,"aspectRatio":69,"alt":10,"title":10,"base64":107,"bgColor":108},"/assets/datocms/1761477623-home-3.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 480w,/assets/datocms/1761477623-home-3.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 960w,/assets/datocms/1761477623-home-3.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1440w,/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=2440&q=85&w=2440 1920w","(max-width: 1920px) 100vw, 1920px","/assets/datocms/1761477623-home-3.jpg?auto=format&fit=max&h=2440&q=85&w=2440","data:image/jpeg;base64,","#d59862",{"id":110,"title":111,"text":112,"media":113},"JVCyVospRVmHgw21wJILjA","INVESTIGACIÓN, FORMACIÓN Y EVENTOS","\u003Cp>La transformaci&oacute;n de los marcos jur&iacute;dicos requiere evidencia y an&aacute;lisis riguroso. En R&iacute;os trabajamos para traducir esos hallazgos en herramientas de formaci&oacute;n accesibles y generar espacios de intercambio con tomadores de decisiones para convertir las ideas en cambios tangibles.\u003C/p>",{"id":114,"alt":10,"title":10,"focalPoint":115,"width":118,"height":119,"thumbnail":120,"small":121,"medium":122,"responsiveImage":123,"video":10},"RebvjtGsQAGdBIdMRdg0WQ",{"x":116,"y":117},0.74,0.49,3936,2624,"/assets/datocms/1761477623-home-5.jpg?auto=format&fit=max&h=600&q=85&w=600","/assets/datocms/1761477623-home-5.jpg?auto=format&fit=max&h=1000&q=85&w=1000","/assets/datocms/1761477623-home-5.jpg?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":124,"webpSrcSet":20,"sizes":65,"src":125,"width":67,"height":68,"aspectRatio":126,"alt":10,"title":10,"base64":127,"bgColor":128},"/assets/datocms/1761477623-home-5.jpg?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,/assets/datocms/1761477623-home-5.jpg?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,/assets/datocms/1761477623-home-5.jpg?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,/assets/datocms/1761477623-home-5.jpg?auto=format&fit=max&h=2440&q=85&w=2440 2440w,/assets/datocms/1761477623-home-5.jpg?auto=format&dpr=1.5&fit=max&h=2440&q=85&w=2440 3660w","/assets/datocms/1761477623-home-5.jpg?auto=format&fit=max&h=2440&q=85&w=2440",1.5000000000000002,"data:image/jpeg;base64,","#f3d963",1781273555347]